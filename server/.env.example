# ─── ArenaLink Server Config ──────────────────────────────────────────────────
#
# Copy this file to .env (or any name) and fill in your values.
#
# Load order (highest wins):
#   1. CLI flag          cargo run -- --port 8080
#   2. Real env var      SERVER_PORT=8080 cargo run
#   3. This file         (values below)
#   4. Built-in default
#
# Usage:
#   cargo run                          # loads .env automatically
#   cargo run -- --config prod.env     # loads a specific file
#   cargo run -- -c prod.env           # same, short flag

# ─── HTTP API Server ───────────────────────────────────────────────────────────

# Address to bind on. 0.0.0.0 = all interfaces, 127.0.0.1 = localhost only.
SERVER_ADDR=0.0.0.0

# Port for the HTTP REST API and WebSocket endpoint.
SERVER_PORT=9090

# ─── Discord Bot ───────────────────────────────────────────────────────────────
# Get your bot token from https://discord.com/developers/applications
# → Your Application → Bot → Token → Reset Token

DISCORD_BOT_TOKEN=your-bot-token-here

# Set to "false" to disable the bot without removing the token.
DISCORD_ENABLED=true

# ── Channel & Guild IDs ────────────────────────────────────────────────────────
# How to find IDs: enable Discord Developer Mode (Settings → Advanced → Developer Mode)
# then right-click a server/channel → Copy Server ID / Copy Channel ID.

# The channel where pit alert messages will be posted.
DISCORD_PIT_ALERTS_CHANNEL_ID=1514693889062207498

# Your Discord server (guild) ID. Used for guild-scoped operations.
DISCORD_GUILD_ID=874948692518502450

# ── Role IDs for @-mentions ────────────────────────────────────────────────────
# When a role ID is set, ArenaLink will @-mention that role when posting alerts
# for the matching recipient type. Leave as 0 (or omit) to skip that ping.
#
# IMPORTANT: these must be the numeric role snowflake IDs, NOT the role name.
# Right-click a role in Server Settings → Roles → Copy Role ID.
#
# Example:
#   DISCORD_ROLE_FTA=123456789012345678
#
# Leaving a role at 0 means alerts assigned to that recipient will post without
# a mention — the message still appears in the channel, just no notification.

# Field Technical Advisor
DISCORD_ROLE_FTA=0

# FTA Advisor / Assistant
DISCORD_ROLE_FTAA=0

# Control System Advisor
DISCORD_ROLE_CSA=874949052515618847

# Robot Inspector
DISCORD_ROLE_INSPECTOR=874949052515618847

# Head Referee
DISCORD_ROLE_REFEREE=0

# Lead Robot Inspector
DISCORD_ROLE_LRI=874949052515618847
